# STOREmind — Environment Config. Copy to .env. NEVER commit .env to git.

ANTHROPIC_API_KEY=sk-ant-api03-...

SHOPIFY_SHOP_NAME=your-store
SHOPIFY_ACCESS_TOKEN=shpat_...
SHOPIFY_API_VERSION=2024-01

KLAVIYO_API_KEY=pk_...
FROM_EMAIL=hello@yourstore.com
FROM_NAME=Your Store

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_CHANNEL=#alerts
SLACK_FRAUD_CHANNEL=#fraud

AUTO_START=true
CYCLE_INTERVAL=60
CART_THRESHOLD=50
FRAUD_THRESHOLD=0.8
RECOVERY_DISCOUNT=15
STOCK_THRESHOLD=10
ENABLE_CART_RECOVERY=true
ENABLE_FRAUD_CANCEL=true
ENABLE_INVENTORY_ALERTS=true
ENABLE_CAMPAIGNS=false
DEMO_MODE=false

# Merchant contact (for onboarding + digest emails)
MERCHANT_EMAIL=
MERCHANT_NAME=Store Owner

PORT=3001
NODE_ENV=development
